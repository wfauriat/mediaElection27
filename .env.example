# Copy to .env for local dev. Production values live in AWS Secrets Manager.

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://media27:media27@localhost:5432/media27
DATABASE_URL_SYNC=postgresql+psycopg://media27:media27@localhost:5432/media27

# Local raw-feed cache (replaced by S3 in prod)
RAW_FEED_DIR=./raw
S3_RAW_BUCKET=

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Ingest behaviour
INGEST_TIMEOUT_SECONDS=30
INGEST_MAX_PARALLEL=8
INGEST_USER_AGENT=Mozilla/5.0 (compatible; mediaElection27/0.1; +https://github.com/wfauriat/mediaElection27)

# AWS (filled at deploy time; empty for pure local dev)
AWS_REGION=eu-west-3
